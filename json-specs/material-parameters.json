    {
        "pointer": "/T0",
        "type": "include",
        "spec_file": "value-no.json",
        "doc": "Reference temperature"
    },
    {
        "pointer": "/heat_capacity",
        "type": "include",
        "spec_file": "value1.json",
        "default": 1,
        "doc": "Specific heat capacity used by the temperature block"
    },
    {
        "pointer": "/conductivity",
        "type": "include",
        "spec_file": "value1.json",
        "default": 1,
        "doc": "Thermal conductivity used by the temperature block"
    },
    {
        "pointer": "/elastic_material",
        "type": "include",
        "spec_file": "elastic-material-parameters.json",
        "doc": "Elastic material object used by the displacement block."
