    {
        "pointer": "/auxiliary_space_id",
        "type": "int",
        "min": 0,
        "doc": "FE space ID for the auxiliary solution"
    },
    {
        "pointer": "/epsilon",
        "type": "include",
        "spec_file": "value-no.json",
        "doc": "permittivity"
    }
]
